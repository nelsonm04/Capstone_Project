<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.capstone.SignUpController">

    <!-- Background -->
    <AnchorPane prefHeight="600" prefWidth="1000" style="-fx-background-image: url('images/background.jpg');                 -fx-background-size: stretch; /* Ensures full coverage */                 -fx-background-position: center;                 -fx-background-repeat: no-repeat;">
    </AnchorPane>

    <!-- Centered SignUp Form -->
    <VBox alignment="CENTER" layoutX="250" layoutY="100" prefWidth="300" spacing="10">

        <!-- Logo -->
        <ImageView fitHeight="80" fitWidth="120">
            <image>
                <Image url="file:src/main/resources/Images/Logo.png" />
            </image>
        </ImageView>

        <!-- Form Container -->
        <VBox prefHeight="250.0" prefWidth="420.0" spacing="10" style="-fx-background-color: rgba(0, 0, 0, 0.8); -fx-padding: 20; -fx-background-radius: 10;">

            <!-- Email -->
            <Label style="-fx-font-size: 18px; -fx-text-fill: white;" text="Email:" />
            <TextField fx:id="signUpEmail" promptText="Email" />

            <!-- Password -->
            <Label style="-fx-font-size: 18px; -fx-text-fill: white;" text="Password:" />
            <PasswordField fx:id="signUpPassword" promptText="Password" />

            <!-- Confirm Password -->
            <Label style="-fx-font-size: 18px; -fx-text-fill: white;" text="Confirm Password:" />
            <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" />

            <!-- Buttons -->
            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="backButton" onAction="#handleBack" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px;" text="Back" />
                <Button fx:id="registerButton1" onAction="#handleSignUp" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-size: 14px;" text="Register" />
            </HBox>

            <!-- Password Match Label -->
            <Label fx:id="passwordMatch" style="-fx-font-size: 14px; -fx-text-fill: red;" />
        </VBox>
    </VBox>

</AnchorPane>

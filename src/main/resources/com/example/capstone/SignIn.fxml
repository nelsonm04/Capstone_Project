<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.capstone.SignInController">

   <!-- Background -->
   <AnchorPane prefHeight="600" prefWidth="1000" style="-fx-background-image: url('images/background.jpg');
                -fx-background-size: stretch; /* Ensures full coverage */
                -fx-background-position: center;
                -fx-background-repeat: no-repeat;">
   </AnchorPane>

   <!-- Centered SignIn Form -->
   <VBox alignment="CENTER" layoutX="250" layoutY="100" prefWidth="300" spacing="10">

      <!-- Logo -->
      <ImageView fitHeight="80" fitWidth="120">
         <image>
            <Image url="file:src/main/resources/Images/Logo.png"/>
         </image>
      </ImageView>

      <!-- Form Container -->
      <VBox prefHeight="200.0" prefWidth="420.0" spacing="10" style="-fx-background-color: rgba(0, 0, 0, 0.8); -fx-padding: 20; -fx-background-radius: 10;">

         <!-- Email -->
         <Label text="Email:" style="-fx-font-size: 18px; -fx-text-fill: white;"/>
         <TextField fx:id="userEmail" promptText="Email" />

         <!-- Password -->
         <Label text="Password:" style="-fx-font-size: 18px; -fx-text-fill: white;"/>
         <PasswordField fx:id="userPassword" promptText="Password" />

         <!-- Buttons -->
         <HBox spacing="10" alignment="CENTER">
            <Button fx:id="userLogIn" onAction="#userSignIn" style="-fx-background-color: #007bff; -fx-text-fill: white; -fx-font-size: 14px;" text="Log In"/>
            <Button fx:id="userSignUp" onAction="#handleSignUp" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-font-size: 14px;" text="Sign Up"/>
         </HBox>

      </VBox>

   </VBox>

</AnchorPane>
